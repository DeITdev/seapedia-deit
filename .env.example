# Supabase PostgreSQL connection.
# DATABASE_URL uses the pooled (pgbouncer) connection for the app at runtime.
# DIRECT_URL uses the direct connection and is required for Prisma migrations.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Secret used to sign session JWTs. Use a long random string in production.
# Generate one with: openssl rand -base64 48
AUTH_SECRET="replace-with-a-long-random-secret"

# Public base URL of the app.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

// SEAPEDIA Prisma schema.
// Level 1: User, UserRole, ApplicationReview.
// Level 2: Store, Product. Later levels add wallet, cart, orders, etc.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Active-role candidates. ADMIN is handled separately from the non-admin
// multi-role set (BUYER, SELLER, DRIVER) per the SEAPEDIA brief.
enum Role {
  ADMIN
  SELLER
  BUYER
  DRIVER
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  email        String     @unique
  passwordHash String
  // Admin accounts are privileged and provisioned via seed/documented setup.
  isAdmin      Boolean    @default(false)
  roles        UserRole[]
  store        Store?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("users")
}

// A non-admin user may own multiple roles at the same time. The active role is
// tracked per session (in the JWT), never on the user record.
model UserRole {
  id     String @id @default(cuid())
  userId String
  role   Role
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

// Public website/experience review (not a product or order review). Guests may
// submit. Comment is stored as raw text and always rendered as escaped text.
model ApplicationReview {
  id        String   @id @default(cuid())
  name      String
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  @@map("application_reviews")
}

// One store per Seller; store name is globally unique across SEAPEDIA.
model Store {
  id        String    @id @default(cuid())
  name      String    @unique
  sellerId  String    @unique
  seller    User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("stores")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Int
  stock       Int
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

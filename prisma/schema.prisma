// SEAPEDIA Prisma schema.
// Level 1: User, UserRole, ApplicationReview.
// Level 2: Store, Product.
// Level 3: Wallet, BuyerAddress, Cart, Order.
// Level 4: Voucher, Promo, order discount breakdown.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SELLER
  BUYER
  DRIVER
}

enum DeliveryMethod {
  INSTANT
  NEXT_DAY
  REGULAR
}

enum OrderStatus {
  SEDANG_DIKEMAS
  MENUNGGU_PENGIRIM
  SEDANG_DIKIRIM
  PESANAN_SELESAI
  DIKEMBALIKAN
}

enum WalletTransactionType {
  TOP_UP
  CHECKOUT
  REFUND
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  email        String        @unique
  passwordHash String
  isAdmin      Boolean       @default(false)
  roles        UserRole[]
  store        Store?
  wallet       Wallet?
  address      BuyerAddress?
  cart         Cart?
  buyerOrders  Order[]       @relation("BuyerOrders")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("users")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  role   Role
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model ApplicationReview {
  id        String   @id @default(cuid())
  name      String
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  @@map("application_reviews")
}

model Store {
  id        String    @id @default(cuid())
  name      String    @unique
  sellerId  String    @unique
  seller    User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  products  Product[]
  carts     Cart[]
  orders    Order[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("stores")
}

model Product {
  id          String     @id @default(cuid())
  name        String
  description String
  price       Int
  stock       Int
  storeId     String
  store       Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("products")
}

model Wallet {
  id           String              @id @default(cuid())
  userId       String              @unique
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Int                 @default(0)
  transactions WalletTransaction[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@map("wallets")
}

model WalletTransaction {
  id        String                @id @default(cuid())
  walletId  String
  wallet    Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type      WalletTransactionType
  amount    Int
  orderId   String?
  order     Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)
  note      String?
  createdAt DateTime              @default(now())

  @@map("wallet_transactions")
}

// One address per buyer for Level 3. userId unique can be relaxed later for an address book.
model BuyerAddress {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipientName String
  phone         String
  street        String
  city          String
  province      String
  postalCode    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("buyer_addresses")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId   String?
  store     Store?     @relation(fields: [storeId], references: [id], onDelete: SetNull)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Voucher {
  id             String       @id @default(cuid())
  code           String       @unique
  discountType   DiscountType
  discountValue  Int
  maxDiscount    Int?
  remainingUsage Int
  expiresAt      DateTime
  orders         Order[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("vouchers")
}

model Promo {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Int
  maxDiscount   Int?
  expiresAt     DateTime
  orders        Order[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("promos")
}

model Order {
  id              String               @id @default(cuid())
  buyerId         String
  buyer           User                 @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  storeId         String
  store           Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deliveryMethod  DeliveryMethod
  recipientName   String
  phone           String
  street          String
  city            String
  province        String
  postalCode      String
  subtotal        Int
  discount        Int                  @default(0)
  voucherDiscount Int                  @default(0)
  promoDiscount   Int                  @default(0)
  voucherId       String?
  voucher         Voucher?             @relation(fields: [voucherId], references: [id], onDelete: SetNull)
  voucherCode     String?
  promoId         String?
  promo           Promo?               @relation(fields: [promoId], references: [id], onDelete: SetNull)
  promoCode       String?
  deliveryFee     Int
  ppn             Int
  finalTotal      Int
  status          OrderStatus          @default(SEDANG_DIKEMAS)
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]
  walletTxns      WalletTransaction[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName String
  unitPrice   Int
  quantity    Int

  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  createdAt DateTime    @default(now())

  @@map("order_status_history")
}
